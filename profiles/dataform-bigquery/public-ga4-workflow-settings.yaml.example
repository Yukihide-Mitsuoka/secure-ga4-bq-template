# Credential-free compilation example for Google's public, obfuscated GA4 ecommerce
# sample. Copy over transform/workflow_settings.yaml after profile activation.
defaultProject: example-verification-project
defaultLocation: US
defaultDataset: ga4_verify_example_staging
defaultAssertionDataset: ga4_verify_example_staging

vars:
  staging_dataset: ga4_verify_example_staging
  intermediate_dataset: ga4_verify_example_intermediate
  marts_dataset: ga4_verify_example_marts

  # Compilation accepts these obvious placeholders. Replace them with Terraform
  # output policy_tag_ids before any credentialed Dataform run.
  policy_tag_high: projects/example-verification-project/locations/us/taxonomies/example/policyTags/high
  policy_tag_medium: projects/example-verification-project/locations/us/taxonomies/example/policyTags/medium
  policy_tag_low: projects/example-verification-project/locations/us/taxonomies/example/policyTags/low

  ga4_export_project: bigquery-public-data
  ga4_export_dataset: ga4_obfuscated_sample_ecommerce

# Do not add this public source to cost_gate_source_datasets. Google owns its IAM;
# Terraform manages reader grants only for private source datasets and managed layers.
