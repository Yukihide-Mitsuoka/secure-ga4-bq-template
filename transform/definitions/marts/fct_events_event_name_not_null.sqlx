config {
  type: "assertion",
  description: "event_name must not be null (mirror of the dbt not_null test). Manual assertion instead of the built-in nonNull: fct_events enforces requirePartitionFilter, so the assertion query MUST carry a partition window or BigQuery rejects it."
}

select 1 as assertion_failure
from ${ref("fct_events")}
where event_date >= date_sub(current_date(), interval 3 day)
  and event_name is null
